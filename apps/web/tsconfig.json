{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "incremental": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "next.config.ts",
    "tailwind.config.ts",
    "middleware.ts",
    ".next/types/**/*.ts"
  ],
  "references": [
    { "path": "../../packages/types" },
    { "path": "../../packages/utils" },
    { "path": "../../packages/constants" },
    { "path": "../../packages/config" },
    { "path": "../../packages/validation" },
    { "path": "../../packages/auth" },
    { "path": "../../packages/api-client" },
    { "path": "../../packages/feature-flags" },
    { "path": "../../packages/design-system" },
    { "path": "../../packages/ui" }
  ],
  "exclude": ["node_modules"]
}
